@model System.Web.Mvc.HandleErrorInfo

@{
    ViewBag.Title = "System Error";
}

<div class="container h-100 mt-5">
    <div class="jumbotron bg-light p-5 rounded">
        <h1 class="display-4 text-danger">Oops! Something went wrong.</h1>
        <p class="lead">We are sorry, but an unexpected error occurred while processing your request.</p>
        <hr class="my-4">
        <p>Our engineering team has been notified. Please try again later, or return to the homepage.</p>
        @Html.ActionLink("Go Back Home", "Index", "Home", null, new { @class = "btn btn-primary btn-lg" })
    </div>

    @if (Model != null)
    {
        <div class="card mt-4 border-danger">
            <div class="card-header bg-danger text-white">
                <strong>Technical Details (Dev Mode)</strong>
            </div>
            <div class="card-body">
                <p><strong>Failed Controller:</strong> @Model.ControllerName</p>
                <p><strong>Failed Action:</strong> @Model.ActionName</p>
                <p><strong>Exception Message:</strong> @Model.Exception.Message</p>

                <hr />
                <pre class="bg-dark text-light p-3 rounded" style="max-height: 300px; overflow-y: auto;">
                    @Model.Exception.StackTrace
                </pre>
            </div>
        </div>
    }
</div>
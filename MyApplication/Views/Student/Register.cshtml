
@model MyApplication.Models.Student

@{
    ViewBag.Title = "Register Student";
}


<!DOCTYPE html>
<html class="h-100">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <!-- Optimized: Replaced hardcoded links with the Bundle -->
    @Styles.Render("~/Styles/bootstrap")
</head>
<body class="h-100">
    <div class="container h-100">
        <div class="d-flex flex-column justify-content-center align-content-center h-100 bg-light">
            @Html.ActionLink("Go to Home Page", "Index", "Home", null, new { @class = "link text-center mb-5" })

            <img src="~/Content/Images/random-school.png" class="img-thumbnail rounded mx-auto mb-4" width="200" height="200" />

            <h1 class="text-center">
                Register your Profile Info Below
            </h1>

            @* HTML.BeginForm -> the htmlAttributes has one less object than the label and input *@
            @using (Html.BeginForm("Register", "Student", FormMethod.Post, new { @class = "d-flex flex-column p-5" }))
            {
                @Html.AntiForgeryToken()


                <div class="form-group">
                    @Html.LabelFor(model => model.Email, "Student Email")
                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", type = "email" } })
                    <small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small>
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.Name, "Student Name")
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control", type = "text" } })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Age, "Student Age")
                    @Html.EditorFor(model => model.Age, new { htmlAttributes = new { @class = "form-control", type = "number", max = 120, min = 18 } })
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" class="form-check-input" id="exampleCheck1">
                    <label class="form-check-label" for="exampleCheck1">I Agree with Sharing my personal data with this institution.</label>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>

            }
        </div>

    </div>

    <!-- This expects "~/Scripts/ui" to exist in BundleConfig.cs -->
    @Scripts.Render("~/Scripts/ui")
</body>
</html>